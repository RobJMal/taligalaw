<?xml version="1.0"?>
<!--
  Synthetic 10-DOF serial arm for benchmarking (a longer chain than 6-DOF).
  Same parser constraints as arm_6dof.urdf: all revolute, every joint has
  origin(xyz+rpy) + axis + limit, links in kinematic-chain order (base first).
-->
<robot name="simple_arm_10dof">

  <material name="grey">
    <color rgba="0.4 0.4 0.4 1.0"/>
  </material>

  <!-- ===== LINKS: base_link + link_1..link_10 ===== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.15" length="0.1"/></geometry>
      <material name="grey"/>
    </visual>
  </link>

  <link name="link_1">
    <visual><origin xyz="0 0 0.1" rpy="0 0 0"/><geometry><cylinder radius="0.05" length="0.2"/></geometry><material name="grey"/></visual>
  </link>
  <link name="link_2">
    <visual><origin xyz="0 0 0.1" rpy="0 0 0"/><geometry><cylinder radius="0.05" length="0.2"/></geometry><material name="grey"/></visual>
  </link>
  <link name="link_3">
    <visual><origin xyz="0 0 0.1" rpy="0 0 0"/><geometry><cylinder radius="0.048" length="0.2"/></geometry><material name="grey"/></visual>
  </link>
  <link name="link_4">
    <visual><origin xyz="0 0 0.1" rpy="0 0 0"/><geometry><cylinder radius="0.046" length="0.2"/></geometry><material name="grey"/></visual>
  </link>
  <link name="link_5">
    <visual><origin xyz="0 0 0.1" rpy="0 0 0"/><geometry><cylinder radius="0.044" length="0.2"/></geometry><material name="grey"/></visual>
  </link>
  <link name="link_6">
    <visual><origin xyz="0 0 0.1" rpy="0 0 0"/><geometry><cylinder radius="0.042" length="0.2"/></geometry><material name="grey"/></visual>
  </link>
  <link name="link_7">
    <visual><origin xyz="0 0 0.1" rpy="0 0 0"/><geometry><cylinder radius="0.04" length="0.2"/></geometry><material name="grey"/></visual>
  </link>
  <link name="link_8">
    <visual><origin xyz="0 0 0.08" rpy="0 0 0"/><geometry><cylinder radius="0.038" length="0.16"/></geometry><material name="grey"/></visual>
  </link>
  <link name="link_9">
    <visual><origin xyz="0 0 0.06" rpy="0 0 0"/><geometry><cylinder radius="0.036" length="0.12"/></geometry><material name="grey"/></visual>
  </link>
  <link name="link_10">
    <visual><origin xyz="0 0 0.04" rpy="0 0 0"/><geometry><cylinder radius="0.034" length="0.08"/></geometry><material name="grey"/></visual>
  </link>

  <!-- ===== JOINTS: joint_i connects link_{i-1} -> link_i; axes cycle z,y,x ===== -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/><child link="link_1"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-2.9" upper="2.9" effort="100.0" velocity="1.0"/>
  </joint>
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/><child link="link_2"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="100.0" velocity="1.0"/>
  </joint>
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/><child link="link_3"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/><axis xyz="1 0 0"/>
    <limit lower="-2.5" upper="2.5" effort="100.0" velocity="1.0"/>
  </joint>
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/><child link="link_4"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-2.9" upper="2.9" effort="100.0" velocity="1.0"/>
  </joint>
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/><child link="link_5"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="100.0" velocity="1.0"/>
  </joint>
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/><child link="link_6"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/><axis xyz="1 0 0"/>
    <limit lower="-2.5" upper="2.5" effort="100.0" velocity="1.0"/>
  </joint>
  <joint name="joint_7" type="revolute">
    <parent link="link_6"/><child link="link_7"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-2.9" upper="2.9" effort="100.0" velocity="1.0"/>
  </joint>
  <joint name="joint_8" type="revolute">
    <parent link="link_7"/><child link="link_8"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="100.0" velocity="1.0"/>
  </joint>
  <joint name="joint_9" type="revolute">
    <parent link="link_8"/><child link="link_9"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/><axis xyz="1 0 0"/>
    <limit lower="-2.5" upper="2.5" effort="100.0" velocity="1.0"/>
  </joint>
  <joint name="joint_10" type="revolute">
    <parent link="link_9"/><child link="link_10"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-2.9" upper="2.9" effort="100.0" velocity="1.0"/>
  </joint>

</robot>
