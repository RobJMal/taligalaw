<?xml version="1.0"?>
<robot name="rr_prismatic_robot">

  <!-- Base Link fixed to the ground -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.1" radius="0.2"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>

  <!-- Joint 1: Revolute (Rotation around Z) -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>

  <!-- Link 1: Vertical Pillar -->
  <link name="link1">
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.5" radius="0.05"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
  </link>

  <!-- Joint 2: Revolute (Rotation around Y) -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1.0"/>
  </joint>

  <!-- Link 2: Horizontal Housing for the Slide -->
  <link name="link2">
    <visual>
      <origin xyz="0.1 0 0" rpy="0 1.57 0"/>
      <geometry>
        <cylinder length="0.3" radius="0.04"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
  </link>

  <!-- Joint 3: Prismatic (Linear Extension along X) -->
  <joint name="joint3" type="prismatic">
    <parent link="link2"/>
    <child link="ee_link"/>
    <!-- Starts at the end of Link 2 -->
    <origin xyz="0.25 0 0" rpy="0 0 0"/> 
    <!-- Moves along the X axis -->
    <axis xyz="1 0 0"/>
    <!-- Slide limits in meters (Translates from 0cm to 30cm) -->
    <limit lower="0.0" upper="0.3" effort="50.0" velocity="0.2"/>
  </joint>

  <!-- End Effector Link: Sliding Rod -->
  <link name="ee_link">
    <visual>
      <origin xyz="0.1 0 0" rpy="0 1.57 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.02"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
  </link>

</robot>
